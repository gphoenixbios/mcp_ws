# Atlassian Cloud (Jira + Confluence 공용) 인증 정보
# 1. https://id.atlassian.com/manage-profile/security/api-tokens 에서 토큰 생성
# 2. 이 파일을 .env 로 복사 후 값 채우기
#    cp .env.example .env
# 3. .env 는 .gitignore 로 제외됨
#
# 참고: confluence_sync/.env 가 이미 있으면 자동 폴백됨 — 두 모듈은 같은 토큰 공유 가능

ATLASSIAN_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-api-token-here

# (선택) base URL 오버라이드 — 비워두면 sync_config.json 의 jira_base_url 사용
# JIRA_BASE_URL=https://woolimi.atlassian.net
